{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "色研ラボ 問題バンク スキーマ",
  "description": "questions.json のバリデーション用スキーマ。VSCode に $schema を認識させると補完が効きます。",
  "type": "object",
  "required": ["version", "questions"],
  "properties": {
    "version":     { "type": "integer" },
    "description": { "type": "string" },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "cat", "q", "opts", "ans", "exp"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "一意なID。カテゴリ_連番 形式を推奨（例: pccs_029）",
            "pattern": "^[a-z]+_[0-9]{3}$"
          },
          "cat": {
            "type": "string",
            "description": "カテゴリキー",
            "enum": ["pccs", "light", "psych", "harmony", "image", "fashion", "interior", "name"]
          },
          "q": {
            "type": "string",
            "description": "問題文"
          },
          "opts": {
            "type": "array",
            "description": "選択肢。必ず4つ",
            "minItems": 4,
            "maxItems": 4,
            "items": { "type": "string" }
          },
          "ans": {
            "type": "integer",
            "description": "正解の選択肢インデックス（0〜3）",
            "minimum": 0,
            "maximum": 3
          },
          "exp": {
            "type": "string",
            "description": "解説文"
          }
        }
      }
    }
  }
}
